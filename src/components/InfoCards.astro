---
import { infoCards } from '../data/site';
import Icon from './Icon.astro';
import SectionTitle from './SectionTitle.astro';
---

<section class="section" id="informacoes">
	<div class="container">
		<SectionTitle
			eyebrow="Informacoes uteis"
			title="Tudo que voce precisa saber antes de comprar"
			description="Horario, endereco e formas de atendimento em um lugar so."
		/>

		<div class="info-grid">
			{infoCards.map((item) => (
				<article class="info-card">
					<span class="info-card__icon"><Icon name={item.icon} /></span>
					<h3>{item.title}</h3>
					<p>{item.text}</p>
				</article>
			))}
		</div>
	</div>
</section>
