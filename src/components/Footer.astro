---
import { buildWhatsAppLink, company, navItems } from '../data/site';
import Icon from './Icon.astro';

interface Props {
	homePath?: string;
}

const { homePath = '' } = Astro.props;
const whatsappHref = buildWhatsAppLink(`Ola! Quero falar com o ${company.name}.`);
const resolveNavHref = (href: string) => (href.startsWith('#') ? `${homePath}${href}` : href);
---

<footer class="footer">
	<div class="container footer__grid">
		<div class="footer__brand">
			<div class="footer__logo">{company.logo}</div>
			<strong>{company.name}</strong>
			<p>{company.slogan}</p>
			<span>{company.address}</span>
		</div>

		<div class="footer__links">
			<h3>Links rapidos</h3>
			<ul>
				{navItems.map((item) => (
					<li><a href={resolveNavHref(item.href)}>{item.label}</a></li>
				))}
			</ul>
		</div>

		<div class="footer__contact">
			<h3>Contato</h3>
			<a href={company.phoneHref}>{company.phone}</a>
			<a href={whatsappHref} target="_blank" rel="noreferrer">{company.whatsappDisplay}</a>
			<a href={company.emailHref}>{company.emailDisplay}</a>
			<div class="footer__socials">
				<a href={company.instagramUrl} target="_blank" rel="noreferrer" aria-label="Instagram">
					<Icon name="instagram" />
				</a>
				<a href={company.facebookUrl} target="_blank" rel="noreferrer" aria-label="Facebook">
					<Icon name="facebook" />
				</a>
			</div>
		</div>
	</div>

	<div class="container footer__bottom">
		<p>{company.name} • {company.slogan}</p>
		<p>© 2026 Todos os direitos reservados.</p>
	</div>
</footer>
