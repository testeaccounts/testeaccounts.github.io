---
import { buildWhatsAppLink, company } from '../data/site';
import { offers } from '../data/offers';
import OfferCard from './OfferCard.astro';
import SectionTitle from './SectionTitle.astro';

const whatsappHref = buildWhatsAppLink(`Ola! Quero receber as ofertas da semana do ${company.name}.`);
---

<section class="section offers" id="ofertas">
	<div class="container">
		<div class="offers__header">
			<SectionTitle
				eyebrow="Ofertas da semana"
				title="As melhores ofertas para voce economizar"
				description="Escolha seus produtos e adicione na lista com um toque."
			/>
			<div class="offers__promo">
				<span>Cupom de desconto</span>
				<strong>Use {company.coupon} na primeira compra</strong>
				<p>Quer ajuda para comprar? Fale com a loja no WhatsApp.</p>
				<a class="button button--primary" href={whatsappHref} target="_blank" rel="noreferrer">Falar no WhatsApp</a>
			</div>
		</div>

		<div class="offers__grid">
			{offers.map((offer) => (
				<OfferCard offer={offer} />
			))}
		</div>
	</div>
</section>
