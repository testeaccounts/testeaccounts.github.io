	oil: `<svg viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg"><rect x="90" y="26" width="40" height="28" rx="12" fill="#24476E"/><path d="M78 56h64v26c0 8-2 15-8 22l-8 11v54c0 12-8 20-18 20h-6c-10 0-18-8-18-20v-54l-8-11c-6-7-8-14-8-22V56Z" fill="#FF9B30"/><rect x="88" y="94" width="44" height="42" rx="12" fill="#FFF2D6"/></svg>`,
	coffee: `<svg viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg"><rect x="68" y="38" width="84" height="148" rx="26" fill="#6D4633"/><rect x="82" y="62" width="56" height="36" rx="16" fill="#E5D3BE"/><rect x="88" y="120" width="44" height="42" rx="14" fill="#FFF7E8"/></svg>`,
