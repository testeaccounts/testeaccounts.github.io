	produce: `<svg viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg"><rect x="38" y="108" width="144" height="72" rx="22" fill="#A56F32"/><circle cx="82" cy="104" r="20" fill="#FF695A"/><circle cx="116" cy="92" r="20" fill="#FFCF45"/><circle cx="146" cy="106" r="18" fill="#67D75C"/><path d="M60 98c16-18 30-28 42-28 11 0 20 4 26 12 8-14 18-22 34-22 12 0 24 6 34 18" stroke="#5AAC45" stroke-width="12" stroke-linecap="round"/></svg>`,
