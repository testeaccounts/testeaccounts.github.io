---
import ProductVisual from './ProductVisual.astro';
import Icon from './Icon.astro';

interface Props {
	product: {
		name: string;
		description: string;
		price: number;
		oldPrice: number;
		unit: string;
		badge: string;
		visual: string;
		sector?: string;
		productType?: string;
		brand?: string;
		tags?: string[];
	};
}

const { product } = Astro.props;
const basePath = import.meta.env.BASE_URL;

const formatPrice = (value: number) =>
	new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);

const normalizeTag = (value: string) =>
	value
		.toLowerCase()
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.replace(/[^\w\s-]/g, '')
		.trim();

const allTags = Array.from(
	new Set(
		[
			...(product.tags ?? []),
			product.badge ?? '',
			product.sector ?? '',
			product.productType ?? '',
			product.brand ?? '',
		]
			.map(normalizeTag)
			.filter(Boolean)
	)
);

const buildTagHref = (tag: string) => `${basePath}produtos/?tag=${encodeURIComponent(tag)}`;
---

<article class="product-card">
	<button class="product-card__favorite" type="button" aria-label={`Favoritar ${product.name}`}>
		<Icon name="heart" />
	</button>
	<a class="product-card__badge product-card__badge--link" href={buildTagHref(normalizeTag(product.badge))}>
		{product.badge}
	</a>
	<div class="product-card__media">
		<ProductVisual type={product.visual} label={product.unit} />
	</div>
	<div class="product-card__content">
		<h3>{product.name}</h3>
		<p>{product.description}</p>
		{allTags.length > 0 && (
			<div class="product-card__tags" aria-label="Tags do produto">
				{allTags.slice(0, 4).map((tag) => (
					<a class="product-card__tag-link" href={buildTagHref(tag)}>
						#{tag}
					</a>
				))}
			</div>
		)}
		<div class="product-card__price">
			<small>{formatPrice(product.oldPrice)}</small>
			<strong>{formatPrice(product.price)}</strong>
			<span>{product.unit}</span>
		</div>
	</div>
	<button
		class="button button--green button--block"
		type="button"
		data-add-to-list
		data-name={product.name}
		data-unit={product.unit}
		data-price={formatPrice(product.price)}
	>
		Adicionar a lista
	</button>
</article>
