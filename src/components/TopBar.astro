---
import { accessibilityLinks, utilityLinks } from '../data/site';
---

<div class="top-access">
	<div class="container top-access__inner">
		{accessibilityLinks.map((link, index) => (
			<a href={link.href}>
				<span>{link.label}</span>
				<strong>{index + 1}</strong>
			</a>
		))}
	</div>
</div>

<div class="utility-bar">
	<div class="container utility-bar__inner">
		<p>Retirada na loja • Entrega local • Entrega sem contato</p>
		<nav aria-label="Atalhos institucionais">
			{utilityLinks.map((item) => (
				<a href={item.href}>{item.label}</a>
			))}
		</nav>
	</div>
</div>
