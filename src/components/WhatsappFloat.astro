---
import { buildWhatsAppLink, company } from '../data/site';
import Icon from './Icon.astro';

const whatsappHref = buildWhatsAppLink(`Ola! Quero comprar no ${company.name}.`);
---

<a class="whatsapp-float" href={whatsappHref} target="_blank" rel="noreferrer" aria-label="Falar no WhatsApp">
	<Icon name="whatsapp" />
	<span>WhatsApp</span>
</a>
