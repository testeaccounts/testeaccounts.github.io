---
import { buildWhatsAppLink, company } from '../data/site';
import Icon from './Icon.astro';
import SectionTitle from './SectionTitle.astro';

const whatsappHref = buildWhatsAppLink(`Ola! Quero falar com o ${company.name}.`);
const mapsQuery = encodeURIComponent(company.address);
---

<section class="section contact" id="contato">
	<div class="container">
		<SectionTitle
			eyebrow="Contato"
			title="Fale com a loja do jeito mais facil"
			description="Voce pode ligar, chamar no WhatsApp ou enviar a mensagem pelo formulario."
		/>

		<div class="contact__grid">
			<div class="contact__panel">
				<div class="contact__map">
					<iframe
						src={`https://www.google.com/maps?q=${mapsQuery}&output=embed`}
						title={`Mapa de ${company.name}`}
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
					></iframe>
				</div>

				<div class="contact__details">
					<a class="contact__item" href={company.phoneHref}>
						<Icon name="phone" />
						<div>
							<strong>Telefone</strong>
							<span>{company.phone}</span>
						</div>
					</a>
					<a class="contact__item" href={whatsappHref} target="_blank" rel="noreferrer">
						<Icon name="whatsapp" />
						<div>
							<strong>WhatsApp</strong>
							<span>{company.whatsappDisplay}</span>
						</div>
					</a>
					<a class="contact__item" href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`} target="_blank" rel="noreferrer">
						<Icon name="location" />
						<div>
							<strong>Endereco</strong>
							<span>{company.address}</span>
						</div>
					</a>
				</div>

				<div class="contact__socials">
					<a href={company.instagramUrl} target="_blank" rel="noreferrer"><Icon name="instagram" /> {company.instagram}</a>
					<a href={company.facebookUrl} target="_blank" rel="noreferrer"><Icon name="facebook" /> {company.facebook}</a>
				</div>
			</div>

			<form class="contact__form" data-contact-form>
				<div class="contact__form-head">
					<span>Fale conosco</span>
					<h3>Envie sua mensagem</h3>
					<p>Quando clicar em enviar, abrimos o WhatsApp com a mensagem pronta.</p>
				</div>

				<label>
					<span>Nome</span>
					<input type="text" name="nome" placeholder="Seu nome" required />
				</label>
				<label>
					<span>Telefone</span>
					<input type="tel" name="telefone" placeholder="(00) 00000-0000" required />
				</label>
				<label>
					<span>Mensagem</span>
					<textarea name="mensagem" rows="5" placeholder="Ola! Gostaria de saber mais sobre ofertas, retirada ou entrega." required></textarea>
				</label>

				<button class="button button--primary" type="submit">Enviar mensagem</button>
				<p class="contact__status" data-contact-status>Seu texto vai para o WhatsApp da loja.</p>
			</form>
		</div>
	</div>

	<script is:inline>
		const contactForm = document.querySelector('[data-contact-form]');

		if (contactForm instanceof HTMLFormElement) {
			const status = contactForm.querySelector('[data-contact-status]');

			contactForm.addEventListener('submit', (event) => {
				event.preventDefault();

				const data = new FormData(contactForm);
				const name = String(data.get('nome') ?? '').trim();
				const phone = String(data.get('telefone') ?? '').trim();
				const message = String(data.get('mensagem') ?? '').trim();
				const lines = [
					'Ola! Quero falar com o Nome da sua empresa.',
					`Nome: ${name}`,
					`Telefone: ${phone}`,
					`Mensagem: ${message}`,
				];

				window.open(`https://wa.me/5500000000000?text=${encodeURIComponent(lines.join('\n'))}`, '_blank', 'noopener');

				if (status instanceof HTMLElement) {
					status.textContent = 'Pronto! Abrimos o WhatsApp com sua mensagem.';
				}

				contactForm.reset();
			});
		}
	</script>
</section>
