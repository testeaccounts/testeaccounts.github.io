---
import { quickAccessItems } from '../data/site';
import Icon from './Icon.astro';
---

<section class="quick-access">
	<div class="container">
		<div class="quick-access__surface">
			<p class="quick-access__eyebrow">Atalhos rapidos para comprar no celular</p>
			<div class="quick-access__grid">
				{quickAccessItems.map((item) => (
					<a class="quick-access__item" href={item.href}>
						<span class="quick-access__icon">
							<Icon name={item.icon} />
						</span>
						<strong>{item.title}</strong>
						<small>{item.subtitle}</small>
					</a>
				))}
			</div>
		</div>
	</div>
</section>
