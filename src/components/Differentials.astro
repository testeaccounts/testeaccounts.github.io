---
import { serviceHighlights, trustHighlights } from '../data/site';
import Icon from './Icon.astro';
import SectionTitle from './SectionTitle.astro';
---

<section class="section differentials">
	<div class="container">
		<SectionTitle
			eyebrow="Facil de usar"
			title="Tudo pensado para voce comprar sem complicacao"
			description="Os botoes estao maiores, os setores estao separados e os caminhos estao mais claros."
		/>

		<div class="differentials__grid">
			{serviceHighlights.map((item) => (
				<article class="service-card">
					<span class="service-card__icon"><Icon name={item.icon} /></span>
					<h3>{item.title}</h3>
					<p>{item.description}</p>
				</article>
			))}
		</div>

		<div class="trust-strip">
			{trustHighlights.map((item) => (
				<div class="trust-strip__item">
					<Icon name={item.icon} />
					<span>{item.title}</span>
				</div>
			))}
		</div>
	</div>
</section>
