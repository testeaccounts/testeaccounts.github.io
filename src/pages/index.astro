---
import About from '../components/About.astro';
import BestSellers from '../components/BestSellers.astro';
import Categories from '../components/Categories.astro';
import Contact from '../components/Contact.astro';
import Differentials from '../components/Differentials.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import InfoCards from '../components/InfoCards.astro';
import Offers from '../components/Offers.astro';
import QuickAccess from '../components/QuickAccess.astro';
import ShoppingList from '../components/ShoppingList.astro';
import Testimonials from '../components/Testimonials.astro';
import WhatsappFloat from '../components/WhatsappFloat.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Nome da sua empresa | Mercado com ofertas e WhatsApp"
	description="Site de mercado com foco em celular, setores separados, ofertas da semana e lista de compras no WhatsApp."
	keywords="mercado na sua cidade, supermercado com entrega, ofertas de supermercado, mercado local com WhatsApp, supermercado no bairro, Nome da sua empresa"
>
	<Header />

	<main id="conteudo">
		<Hero />
		<QuickAccess />
		<BestSellers />
		<Differentials />
		<Categories />
		<Offers />
		<ShoppingList />
		<About />
		<Testimonials />
		<InfoCards />
		<Contact />
	</main>

	<Footer />
	<WhatsappFloat />
</BaseLayout>
